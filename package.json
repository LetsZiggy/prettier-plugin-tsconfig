{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "prettier-plugin-tsconfig",
	"version": "0.0.0",
	"type": "module",
	"description": "A Prettier plugin for formatting tsconfig.json",
	"repository": {
		"type": "git",
		"url": "https://github.com/LetsZiggy/prettier-plugin-tsconfig"
	},
	"homepage": "https://github.com/LetsZiggy/prettier-plugin-tsconfig#readme",
	"contributors": [
		"Shafiq Tahir <shafiqtahir.khan@gmail.com>"
	],
	"license": "MIT",
	"engines": {
		"node": ">=22.0.0"
	},
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"module": "./dist/index.mjs",
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.cjs"
		}
	},
	"files": [
		"./dist"
	],
	"keywords": [
		"formatter",
		"prettier",
		"prettier-plugin",
		"tsconfig.json"
	],
	"scripts": {
		"compile:build": "pnpm run precommit:rm && pnpm run precommit:tsc && pnpm run parcel:build",
		"compile:watch": "pnpm run precommit:rm && pnpm run parcel:watch",
		"parcel:build": "parcel build",
		"parcel:watch": "parcel watch",
		"precommit:eslint": "pnpm exec eslint --max-warnings 0 --no-warn-ignored --fix .",
		"precommit:prettier": "pnpm exec prettier --write .",
		"precommit:rm": "rm -rf ./dist/*",
		"precommit:tsc": "tsc --noEmit",
		"preinstall": "npx only-allow pnpm",
		"test:run": "node ./test/test.spec.ts"
	},
	"peerDependencies": {
		"prettier": "^3.5.3"
	},
	"dependencies": {
		"@babel/types": "^7.28.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.2.0",
		"@commitlint/config-conventional": "^20.2.0",
		"@eslint/js": "^9.30.1",
		"@parcel/bundler-library": "^2.15.4",
		"@parcel/config-default": "^2.15.4",
		"@parcel/packager-ts": "2.16.3",
		"@parcel/transformer-typescript-types": "2.16.3",
		"@stylistic/eslint-plugin": "^5.1.0",
		"@stylistic/eslint-plugin-migrate": "^4.4.1",
		"@total-typescript/ts-reset": "^0.6.1",
		"@total-typescript/tsconfig": "^1.0.4",
		"@types/node": "^25.0.3",
		"eslint": "^9.30.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-n": "^17.21.0",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-sort-class-members": "^1.21.0",
		"eslint-plugin-sort-destructure-keys": "^2.0.0",
		"eslint-plugin-unicorn": "^62.0.0",
		"globals": "^16.3.0",
		"parcel": "^2.15.4",
		"prettier": "^3.6.2",
		"prettier-plugin-pkg": "^0.21.1",
		"tslib": "^2.8.1",
		"type-fest": "^5.3.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.35.1"
	},
	"@parcel/resolver-default": {
		"packageExports": true
	},
	"source": "./src/index.ts",
	"targets": {
		"default": {
			"distDir": "./dist"
		}
	}
}
